# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Local app settings
app_settings.json

# Local Salesforce CLI / SFDX state
.sf_cli_project/
.sfdx/

# Generated outputs
output_test/
excel/
objects/
apex/
flows/
assets/
index.html

# Local project backups and retrieved Salesforce metadata (never committed)
# Any top-level folder ending with an 8-digit date suffix (YYYYMMDD) is treated
# as a per-org retrieve and is excluded from version control.
backup/
/*[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]/

# Reference CSV imported from external tooling (not used at runtime)
static_code_analysis_rules.csv

# OS / editor
.DS_Store
Thumbs.db

# MS Office / Word lock files (created while a .rtf/.docx is open)
~$*
*.tmp
